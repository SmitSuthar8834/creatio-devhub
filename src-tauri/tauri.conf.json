{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "creatio-devhub",
  "version": "0.8.2",
  "identifier": "com.qnt.creatiodevhub",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Creatio DevHub",
        "width": 1240,
        "height": 820,
        "minWidth": 900,
        "minHeight": 620
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDMwNjRGNTk3OTlFNjFGODcKUldTSEgrYVpsL1ZrTUpRUE9GU2tPc2M0cWkyNC95WnFIMW4xMFF0QTY5eGVobFl1M2dHK3FkR00K",
      "endpoints": [
        "https://github.com/SmitSuthar8834/creatio-devhub/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
